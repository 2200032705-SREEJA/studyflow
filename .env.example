# Database (Neon or Supabase Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/studyflow?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# LLM provider (swap client in src/lib/llm.ts if you use a different provider)
LAMATIC_API_KEY=""
LAMATIC_AGENT_URL=""
# Alternative: use Anthropic directly
ANTHROPIC_API_KEY=""

# File storage (used by /api/upload for PDF uploads)
# Example: Vercel Blob
BLOB_READ_WRITE_TOKEN=""
